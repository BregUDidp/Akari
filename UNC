local isTestingUNC = false
local dots = {"", ".", "..", "..."}

local function performUNCTest()
   local success, total = 0, 0
   
   local uncFunctions = {
      getrawmetatable, setreadonly, make_readonly, isreadonly,
      getrenv, getgc, getreg, gethui,
      hookfunction, hookmetamethod, newcclosure,
      firesignal, getconnections, getconnectionstate,
      cloneref, cache.invalidate, cache.iscached,
      decompile, getupvalue, setupvalue, getupvalues,
      getconstants, getconstant, getprotos, getproto,
      is_synapse_function, isexecutorclosure, checkcaller,
   }
   
   for _, func in ipairs(uncFunctions) do
      total = total + 1
      local s = pcall(function() return func ~= nil and (type(func) == "function" or type(func) == "table") end)
      if s then success = success + 1 end
   end
   
   return math.floor((success / total) * 100 + 0.5)
end

local function showUNCResult(percent)
   local colorCode = percent >= 95 and "rgb(0, 255, 100)" or
                     percent >= 85 and "rgb(50, 255, 150)" or
                     percent >= 70 and "rgb(255, 220, 0)" or
                     "rgb(255, 70, 70)"
   
   UNCResultLabel:Set('<font color="' .. colorCode .. '"><b>Your Unc Test Executer:  ' .. percent .. ' %</b></font>')
   
   local statusText = percent >= 95 and "Unc Test Executer Rate:  100 %" or
                      percent >= 85 and "Unc Test Executer Rate:  85 %" or
                      percent >= 70 and "Unc Test Executer Rate:  70 %" or
                      "Your Executer Unc Test:  0 %"
   local statusColor = percent >= 95 and "rgb(0,255,100)" or percent >= 85 and "rgb(255,215,0)" or percent >= 70 and "rgb(255,215,0)" or "rgb(255,80,80)"
   
   UNCStatusLabel:Set('<font color="'..statusColor..'"><b>' .. statusText .. '</b></font>')
   
   UNCDetectLabel:Set(percent >= 92 and '<font color="rgb(0,255,120)"><b>Undetected Executer  100 %</b></font>' or '<font color="rgb(255,80,80)"><b>Detected Executer  100 %</b></font>')
   
   task.delay(7, function()
      UNCResultLabel:Set('<font color="rgb(138, 43, 179)"><b> --- </b></font>')
      UNCStatusLabel:Set('<font color="rgb(138, 43, 179)"><b> --- </b></font>')
      UNCDetectLabel:Set('<font color="rgb(138, 43, 179)"><b> --- </b></font>')
   end)
end

