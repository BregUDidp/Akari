local sUNCDetectLabel = TabSUNC:CreateLabel(
   '<font color="rgb(138, 43, 179)"><b> --- </b></font>'
)

local isTestingSUNC = false

local function performsUNCTest()
   local success, total = 0, 0
   
   -- ตัวอย่างการเช็ค sUNC แบบทำงานจริง (เพิ่มเติมตาม trend 2026)
   local suncTests = {
      function() -- hookfunction ทำงานจริง
         local original = warn
         local hooked = hookfunction(warn, function(...) return original("hooked!") end)
         return hooked == original
      end,
      function() -- newcclosure สร้าง closure ใหม่จริง
         local f = newcclosure(function() return 1 end)
         return type(f) == "function" and iscclosure(f) == false
      end,
      function() -- getrawmetatable ใช้ได้จริง
         local mt = getrawmetatable(game)
         return type(mt) == "table" and rawget(mt, "__index") ~= nil
      end,
      function() return firesignal ~= nil end, -- พื้นฐานแต่เช็คเพิ่ม
      function() return getconnections ~= nil end,
      -- เพิ่มได้อีกตามต้องการ (sUNC จริงมี 50+ tests แต่ที่นี่เวอร์ชันง่าย)
   }
   
   for _, test in ipairs(suncTests) do
      total = total + 1
      local ok = pcall(test)
      if ok then success = success + 1 end
   end
   
   return math.floor((success / total) * 100 + 0.5)
end

