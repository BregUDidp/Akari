-- ================== Button Functions ==================
playerWinButton.MouseButton1Click:Connect(function()
	if gameOver then return end
	
	while not checkWin(1) and not isDraw() do
		local placed = false
		for i = 1, 9 do
			if board[i] == 0 then
				board[i] = 1
				updateBoardUI()
				placed = true
				if checkWin(1) then
					endGame(1)
					return
				end
				break
			end
		end
		if not placed then break end
	end
	
	if not checkWin(1) then
		for i = 1, 9 do
			if board[i] == 0 then
				board[i] = 1
				updateBoardUI()
				if checkWin(1) then
					endGame(1)
					return
				end
			end
		end
	end
end)

